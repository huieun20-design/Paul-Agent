generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  companies     CompanyMember[]
  emailAccounts EmailAccount[]
  todos         Todo[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  OWNER
  STAFF
}

// ============================================
// COMPANY (멀티 회사)
// ============================================

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       CompanyMember[]
  emailAccounts EmailAccount[]
  contacts      Contact[]
  orders        Order[]
  invoices      Invoice[]
  payments      Payment[]
  bankAccounts  BankAccount[]
  claims        Claim[]
  employees     Employee[]
  payrolls      Payroll[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

// ============================================
// EMAIL
// ============================================

model EmailAccount {
  id           String            @id @default(cuid())
  userId       String
  companyId    String?
  provider     EmailProvider
  email        String
  accessToken  String?           @db.Text
  refreshToken String?           @db.Text
  tokenExpiry  DateTime?
  imapHost     String?
  imapPort     Int?
  imapUser     String?
  imapPass     String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])
  emails  Email[]
}

enum EmailProvider {
  GMAIL
  OUTLOOK
  YAHOO
  ICLOUD
  CUSTOM
}

model Email {
  id             String        @id @default(cuid())
  emailAccountId String
  messageId      String        @unique
  threadId       String?
  from           String
  to             String[]
  cc             String[]
  bcc            String[]
  subject        String
  bodyText       String?       @db.Text
  bodyHtml       String?       @db.Text
  date           DateTime
  isRead         Boolean       @default(false)
  isDeleted      Boolean       @default(false)
  folder         EmailFolder   @default(INBOX)
  hasAttachments Boolean       @default(false)
  createdAt      DateTime      @default(now())

  // AI 분석 결과
  category       String?
  priority       EmailPriority?
  extractedData  Json?
  aiSummary      String?       @db.Text
  suggestedActions Json?

  emailAccount   EmailAccount  @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  attachments    Attachment[]
  linkedOrder    Order?        @relation("EmailToOrder")
  linkedInvoice  Invoice?      @relation("EmailToInvoice")
  linkedClaim    Claim?        @relation("EmailToClaim")
  todos          Todo[]        @relation("EmailToTodo")
}

enum EmailFolder {
  INBOX
  SENT
  DRAFTS
  TRASH
  SPAM
}

enum EmailPriority {
  HIGH
  MEDIUM
  LOW
}

model Attachment {
  id        String   @id @default(cuid())
  emailId   String
  filename  String
  mimeType  String
  size      Int
  url       String   @db.Text
  createdAt DateTime @default(now())

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)
}

// ============================================
// CRM (Vendor / Customer)
// ============================================

model Contact {
  id          String      @id @default(cuid())
  companyId   String
  type        ContactType
  companyName String
  contactName String?
  email       String?
  phone       String?
  address     String?     @db.Text
  notes       String?     @db.Text
  vendorScore Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendorOrders    Order[]   @relation("VendorOrders")
  customerOrders  Order[]   @relation("CustomerOrders")
  invoicesAsVendor   Invoice[] @relation("VendorInvoices")
  invoicesAsCustomer Invoice[] @relation("CustomerInvoices")
}

enum ContactType {
  VENDOR
  CUSTOMER
  BOTH
}

// ============================================
// ORDERS
// ============================================

model Order {
  id            String      @id @default(cuid())
  companyId     String
  orderNumber   String
  type          OrderType
  vendorId      String?
  customerId    String?
  status        OrderStatus @default(PENDING)
  items         Json?
  totalAmount   Float?
  currency      String      @default("USD")
  trackingNumber String?
  notes         String?     @db.Text
  orderDate     DateTime    @default(now())
  expectedDate  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // 이메일 기반 자동 생성
  sourceEmailId String?     @unique

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor       Contact? @relation("VendorOrders", fields: [vendorId], references: [id])
  customer     Contact? @relation("CustomerOrders", fields: [customerId], references: [id])
  sourceEmail  Email?   @relation("EmailToOrder", fields: [sourceEmailId], references: [id])
  invoices     Invoice[]
  claims       Claim[]
}

enum OrderType {
  VENDOR
  CUSTOMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  PAID
  CANCELLED
}

// ============================================
// INVOICES & PAYMENTS
// ============================================

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  invoiceNumber String
  type          InvoiceType
  vendorId      String?
  customerId    String?
  orderId       String?
  status        InvoiceStatus @default(UNPAID)
  amount        Float
  paidAmount    Float         @default(0)
  currency      String        @default("USD")
  dueDate       DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sourceEmailId String?       @unique

  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor       Contact?  @relation("VendorInvoices", fields: [vendorId], references: [id])
  customer     Contact?  @relation("CustomerInvoices", fields: [customerId], references: [id])
  order        Order?    @relation(fields: [orderId], references: [id])
  sourceEmail  Email?    @relation("EmailToInvoice", fields: [sourceEmailId], references: [id])
  payments     Payment[]
}

enum InvoiceType {
  VENDOR
  CUSTOMER
}

enum InvoiceStatus {
  PAID
  UNPAID
  OVERDUE
  PARTIAL
}

model Payment {
  id            String        @id @default(cuid())
  companyId     String
  invoiceId     String?
  bankAccountId String?
  type          PaymentType
  amount        Float
  currency      String        @default("USD")
  date          DateTime      @default(now())
  description   String?
  reference     String?
  createdAt     DateTime      @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     Invoice?     @relation(fields: [invoiceId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
}

enum PaymentType {
  INCOMING
  OUTGOING
}

// ============================================
// BANKING
// ============================================

model BankAccount {
  id            String          @id @default(cuid())
  companyId     String
  name          String
  type          BankAccountType
  bankName      String?
  accountNumber String?
  balance       Float           @default(0)
  currency      String          @default("USD")

  // Credit Card specific fields
  creditLimit   Float?
  dueDate       Int?            // Day of month (1-31)
  minimumPay    Float?
  apr           Float?          // Annual percentage rate
  statementDate Int?            // Day of month statement closes

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments     Payment[]
  transactions Transaction[]
}

enum BankAccountType {
  CHECKING
  CREDIT_CARD
  CASH
  SAVINGS
}

model Transaction {
  id            String   @id @default(cuid())
  bankAccountId String
  type          PaymentType
  amount        Float
  balance       Float
  description   String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

// ============================================
// CLAIMS
// ============================================

model Claim {
  id            String      @id @default(cuid())
  companyId     String
  orderId       String?
  title         String
  description   String?     @db.Text
  status        ClaimStatus @default(OPEN)
  priority      EmailPriority @default(MEDIUM)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sourceEmailId String?     @unique

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order       Order?   @relation(fields: [orderId], references: [id])
  sourceEmail Email?   @relation("EmailToClaim", fields: [sourceEmailId], references: [id])
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ============================================
// TODO
// ============================================

model Todo {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?      @db.Text
  priority    EmailPriority @default(MEDIUM)
  dueDate     DateTime?
  isCompleted Boolean      @default(false)
  source      TodoSource   @default(MANUAL)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  sourceEmailId String?

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEmail Email? @relation("EmailToTodo", fields: [sourceEmailId], references: [id])
}

enum TodoSource {
  MANUAL
  AI_EMAIL
  AI_FOLLOWUP
  PHOTO
}

// ============================================
// PAYROLL
// ============================================

model Employee {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  position     String?
  salary       Float
  payType      PayType  @default(PAYROLL)
  cashAmount   Float?
  payrollAmount Float?
  payFrequency String   @default("MONTHLY")
  currency     String   @default("USD")
  startDate    DateTime @default(now())
  isActive     Boolean  @default(true)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrolls Payroll[]
}

enum PayType {
  PAYROLL
  CASH
  MIXED
}

model Payroll {
  id           String      @id @default(cuid())
  companyId    String
  employeeId   String
  amount       Float
  cashAmount   Float       @default(0)
  payrollAmount Float      @default(0)
  currency     String      @default("USD")
  period       String
  status       PayStatus   @default(PAID)
  notes        String?
  paidAt       DateTime    @default(now())
  createdAt    DateTime    @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

enum PayStatus {
  PAID
  PENDING
  PARTIAL
}
